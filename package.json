    "demo": "ts-node demo/run.ts",
    "demo:devnet": "BASIRA_CLUSTER=devnet ts-node demo/run.ts",
    "web": "ts-node web/server.ts",
    "web:devnet": "BASIRA_CLUSTER=devnet ts-node web/server.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/web3.js": "^1.98.0",
